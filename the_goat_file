	"SemaphoreSync": {
  "prefix": "semaphoreSync basic semaphores",
  "body": [
    "#include <stdio.h>",
    "#include <pthread.h>",
    "#include <semaphore.h>",
    "",
    "sem_t sem;",
    "",
    "void* task(void* arg) {",
    "    sem_wait(&sem);",
    "    printf(\"In Critical Section: %s\\n\", (char*)arg);",
    "    sem_post(&sem);",
    "    return NULL;",
    "}",
    "",
    "int main() {",
    "    pthread_t t1, t2;",
    "    sem_init(&sem, 0, 1);",
    "",
    "    pthread_create(&t1, NULL, task, \"Thread 1\");",
    "    pthread_create(&t2, NULL, task, \"Thread 2\");",
    "",
    "    pthread_join(t1, NULL);",
    "    pthread_join(t2, NULL);",
    "    sem_destroy(&sem);",
    "    return 0;",
    "}"
  ],
  "description": "Implements thread synchronization using POSIX semaphores."
},

"MutexLocking": {
  "prefix": "mutex Lock unlock mutex",
  "body": [
    "#include <stdio.h>",
    "#include <pthread.h>",
    "",
    "pthread_mutex_t lock;",
    "int counter = 0;",
    "",
    "void* increment(void* arg) {",
    "    pthread_mutex_lock(&lock);",
    "    counter++;",
    "    printf(\"Counter: %d\\n\", counter);",
    "    pthread_mutex_unlock(&lock);",
    "    return NULL;",
    "}",
    "",
    "int main() {",
    "    pthread_t t1, t2;",
    "    pthread_mutex_init(&lock, NULL);",
    "",
    "    pthread_create(&t1, NULL, increment, NULL);",
    "    pthread_create(&t2, NULL, increment, NULL);",
    "",
    "    pthread_join(t1, NULL);",
    "    pthread_join(t2, NULL);",
    "    pthread_mutex_destroy(&lock);",
    "    return 0;",
    "}"
  ],
  "description": "Uses a mutex to prevent race conditions while incrementing a shared counter."
},

