  "boundedBuffer": {
    "prefix": "bounded Buffer semaphores ",
    "body": [
      "#include <pthread.h>",
      "#include <semaphore.h>",
      "#include <stdio.h>",
      "#include <stdlib.h>",
      "#include <unistd.h>",
      "",
      "#define BUFFER_SIZE 5",
      "#define PRODUCER_LOOPS 10",
      "",
      "int buffer[BUFFER_SIZE];",
      "int in = 0;",
      "int out = 0;",
      "",
      "sem_t empty;",
      "sem_t full;",
      "pthread_mutex_t mutex;",
      "",
      "void* producer(void* arg) {",
      "    for (int i = 0; i < PRODUCER_LOOPS; i++) {",
      "        int item = rand() % 100;",
      "",
      "        sem_wait(&empty);",
      "        pthread_mutex_lock(&mutex);",
      "",
      "        buffer[in] = item;",
      "        printf(\"Producer produced: %d at index %d\\n\", item, in);",
      "        in = (in + 1) % BUFFER_SIZE;",
      "",
      "        pthread_mutex_unlock(&mutex);",
      "        sem_post(&full);",
      "",
      "        sleep(1);",
      "    }",
      "    pthread_exit(NULL);",
      "}",
      "",
      "void* consumer(void* arg) {",
      "    for (int i = 0; i < PRODUCER_LOOPS; i++) {",
      "        sem_wait(&full);",
      "        pthread_mutex_lock(&mutex);",
      "",
      "        int item = buffer[out];",
      "        printf(\"Consumer consumed: %d from index %d\\n\", item, out);",
      "        out = (out + 1) % BUFFER_SIZE;",
      "",
      "        pthread_mutex_unlock(&mutex);",
      "        sem_post(&empty);",
      "",
      "        sleep(2);",
      "    }",
      "    pthread_exit(NULL);",
      "}",
      "",
      "int main() {",
      "    pthread_t prod, cons;",
      "",
      "    sem_init(&empty, 0, BUFFER_SIZE);",
      "    sem_init(&full, 0, 0);",
      "    pthread_mutex_init(&mutex, NULL);",
      "",
      "    pthread_create(&prod, NULL, producer, NULL);",
      "    pthread_create(&cons, NULL, consumer, NULL);",
      "",
      "    pthread_join(prod, NULL);",
      "    pthread_join(cons, NULL);",
      "",
      "    pthread_mutex_destroy(&mutex);",
      "    sem_destroy(&empty);",
      "    sem_destroy(&full);",
      "",
      "    return 0;",
      "}"
    ],
    "description": "C program implementing bounded buffer using pthreads, semaphores, and mutexes."
  },
  "Producer-Consumer (C - Pthreads & Semaphores)": {
    "prefix": "producer consumer malloc calloc",
    "body": [
      "#include <stdio.h>",
      "#include <stdlib.h>",
      "#include <pthread.h>",
      "#include <semaphore.h>",
      "#include <unistd.h>",
      "",
      "#define BUFFER_SIZE 5",
      "#define PRODUCER_COUNT 3",
      "#define CONSUMER_COUNT 2",
      "#define ITEMS_PER_PRODUCER 5",
      "",
      "void *producer(void *arg);",
      "void *consumer(void *arg);",
      "",
      "int *buffer[BUFFER_SIZE];",
      "int in = 0, out = 0;",
      "",
      "sem_t empty, full;",
      "pthread_mutex_t mutex;",
      "",
      "int item_id = 100;",
      "",
      "int main() {",
      "\tpthread_t prod_threads[PRODUCER_COUNT];",
      "\tpthread_t cons_threads[CONSUMER_COUNT];",
      "\tint i;",
      "",
      "\tsem_init(&empty, 0, BUFFER_SIZE);",
      "\tsem_init(&full, 0, 0);",
      "\tpthread_mutex_init(&mutex, NULL);",
      "",
      "\tfor (i = 0; i < PRODUCER_COUNT; i++) {",
      "\t\tint *id = malloc(sizeof(int));",
      "\t\t*id = i + 1;",
      "\t\tpthread_create(&prod_threads[i], NULL, producer, id);",
      "\t}",
      "",
      "\tfor (i = 0; i < CONSUMER_COUNT; i++) {",
      "\t\tint *id = malloc(sizeof(int));",
      "\t\t*id = i + 1;",
      "\t\tpthread_create(&cons_threads[i], NULL, consumer, id);",
      "\t}",
      "",
      "\tfor (i = 0; i < PRODUCER_COUNT; i++) {",
      "\t\tpthread_join(prod_threads[i], NULL);",
      "\t}",
      "",
      "\t// Optional: Let consumers finish by adding poison pills or sleep",
      "\tsleep(2); // crude wait for consumers",
      "\tfor (i = 0; i < CONSUMER_COUNT; i++) {",
      "\t\tpthread_cancel(cons_threads[i]);",
      "\t\tpthread_join(cons_threads[i], NULL);",
      "\t}",
      "",
      "\tsem_destroy(&empty);",
      "\tsem_destroy(&full);",
      "\tpthread_mutex_destroy(&mutex);",
      "",
      "\treturn 0;",
      "}",
      "",
      "void *producer(void *arg) {",
      "\tint id = *((int *)arg);",
      "\tfree(arg);",
      "",
      "\tfor (int i = 0; i < ITEMS_PER_PRODUCER; i++) {",
      "\t\tint *item = malloc(sizeof(int));",
      "\t\t*item = __sync_fetch_and_add(&item_id, 1); // unique item ID",
      "",
      "\t\tsem_wait(&empty);",
      "\t\tpthread_mutex_lock(&mutex);",
      "",
      "\t\tbuffer[in] = item;",
      "\t\tprintf(\"Producer %d produced item: %d\\n\", id, *item);",
      "\t\tin = (in + 1) % BUFFER_SIZE;",
      "",
      "\t\tpthread_mutex_unlock(&mutex);",
      "\t\tsem_post(&full);",
      "",
      "\t\tsleep(1); // simulate work",
      "\t}",
      "",
      "\tpthread_exit(NULL);",
      "}",
      "",
      "void *consumer(void *arg) {",
      "\tint id = *((int *)arg);",
      "\tfree(arg);",
      "",
      "\twhile (1) {",
      "\t\tsem_wait(&full);",
      "\t\tpthread_mutex_lock(&mutex);",
      "",
      "\t\tint *item = buffer[out];",
      "\t\tbuffer[out] = NULL;",
      "\t\tout = (out + 1) % BUFFER_SIZE;",
      "",
      "\t\tpthread_mutex_unlock(&mutex);",
      "\t\tsem_post(&empty);",
      "",
      "\t\tprintf(\"Consumer %d consumed item: %d\\n\", id, *item);",
      "\t\tfree(item);",
      "",
      "\t\tsleep(1); // simulate work",
      "\t}",
      "",
      "\tpthread_exit(NULL);",
      "}"
    ],
