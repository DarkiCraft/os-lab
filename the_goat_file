            "    {\"./hello_world.sh\", 4, 1, 1, 0, 0}",
            "  };",
            "",
            "  int time = 0, done = 0;",
            "",
            "  while (done < N) {",
            "    int idx = -1, min = 999;",
            "",
            "    for (int i = 0; i < N; i++) {",
            "      if (p[i].at <= time && !p[i].finished && p[i].rt < min && p[i].rt > 0) {",
