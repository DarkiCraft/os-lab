"Disk Usage Monitor Bash": {
  "prefix": "disk Monitor bash shell",
  "body": [
    "#!/bin/bash",
    "THRESHOLD=80  # Alert if disk usage exceeds this percentage",
    "",
    "while true; do",
    "    USAGE=$(df / | grep '/' | tr -s ' ' | cut -d' ' -f5 | tr -d '%')",
    "",
    "    echo \"Current Disk Usage: $ USAGE%\"",
    "",
    "    if [ $ USAGE -ge $ THRESHOLD ]; then",
    "        echo \"Warning: Disk space is critically high!\"",
    "    fi",
    "",
    "    sleep 60  # Check every 60 seconds",
    "done"
  ],
  "description": "Monitors disk usage of the root directory and warns if it exceeds a set threshold."
},
