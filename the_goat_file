      "        printf(\"Player %d: %d points\\n\", thread_data[i]->player_id, thread_data[i]->score);",
      "        if (thread_data[i]->score > max_score) {",
      "            max_score = thread_data[i]->score;",
      "            winner = thread_data[i]->player_id;",
      "        }",
      "    }",
      "    printf(\"\\nWinner: Player %d with %d points!\\n\", winner, max_score);",
      "    ",
      "    // Cleanup",
      "    sem_destroy(&semaphore);",
      "    pthread_mutex_destroy(&lock);",
      "    free(answering_order);",
      "    for (int i = 0; i < num_players; i++) free(thread_data[i]);",
      "    ",
      "    return 0;",
      "}"
