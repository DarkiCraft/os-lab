  "dining _philosophers": {
  "prefix": "dining philosophers semaphore signal",
  "body": [
    "#include <pthread.h>",
    "#include <semaphore.h>",
    "#include <signal.h>",
    "#include <stdio.h>",
    "#include <stdlib.h>",
    "#include <unistd.h>",
    "",
    "#define NUM_PHILOSOPHERS 5",
    "#define EATING_TIME 2",
    "#define THINKING_TIME 1",
    "",
    "sem_t forks[NUM_PHILOSOPHERS];",
    "sem_t table;",
    "volatile sig_atomic_t running = 1;",
    "",
    "void handle_signal(int sig);",
    "void *philosopher(void *num);",
    "",
    "int main() {",
    "  pthread_t philosophers[NUM_PHILOSOPHERS];",
    "  signal(SIGINT, handle_signal);",
    "",
    "  for (int i = 0; i < NUM_PHILOSOPHERS; i++) {",
    "    sem_init(&forks[i], 0, 1);",
    "  }",
    "  sem_init(&table, 0, NUM_PHILOSOPHERS - 1);",
    "",
    "  for (int i = 0; i < NUM_PHILOSOPHERS; i++) {",
    "    int *id = malloc(sizeof(int));",
    "    *id = i;",
    "    pthread_create(&philosophers[i], NULL, philosopher, id);",
    "  }",
    "",
    "  while (running) {",
    "    sleep(1);",
    "  }",
    "",
    "  printf(\"\\nShutting down...\\n\");",
    "  for (int i = 0; i < NUM_PHILOSOPHERS; i++) {",
    "    pthread_cancel(philosophers[i]);",
    "  }",
    "",
    "  for (int i = 0; i < NUM_PHILOSOPHERS; i++) {",
    "    pthread_join(philosophers[i], NULL);",
    "  }",
    "",
    "  for (int i = 0; i < NUM_PHILOSOPHERS; i++) {",
    "    sem_destroy(&forks[i]);",
    "  }",
    "  sem_destroy(&table);",
    "",
    "  printf(\"Clean shutdown complete.\\n\");",
    "  return 0;",
    "}",
    "",
    "void handle_signal(int sig) {",
    "  (void)sig;",
    "  running = 0;",
    "}",
    "",
    "void *philosopher(void *num) {",
    "  int id = *(int *)num;",
    "",
    "  while (running) {",
    "    printf(\"Philosopher %d is thinking...\\n\", id);",
    "    sleep(THINKING_TIME);",
    "",
    "    if (!running) break;",
    "",
    "    sem_wait(&table);",
    "    sem_wait(&forks[id]);",
    "    printf(\"Philosopher %d picked up left fork %d\\n\", id, id);",
    "",
    "    sem_wait(&forks[(id + 1) % NUM_PHILOSOPHERS]);",
    "    printf(\"Philosopher %d picked up right fork %d\\n\", id, (id + 1) % NUM_PHILOSOPHERS);",
    "",
    "    printf(\"Philosopher %d is eating...\\n\", id);",
    "    sleep(EATING_TIME);",
    "",
    "    sem_post(&forks[(id + 1) % NUM_PHILOSOPHERS]);",
    "    sem_post(&forks[id]);",
    "    sem_post(&table);",
    "  }",
    "",
    "  printf(\"Philosopher %d is leaving the table\\n\", id);",
    "  free(num);",
    "  return NULL;",
    "}"
  ],
  "description": "Dining Philosophers with semaphore synchronization and signal-safe shutdown"
},

"counter_mutex_increment":{
"prefix": "global counter mutex increment multithreading",
  "body": [
    "#include <pthread.h>",
    "#include <stdio.h>",
    "#include <stdlib.h>",
    "#include <unistd.h>",
    "",
    "#define NUM_THREADS 5",
    "#define INCREMENTS_PER_THREAD 100000",
    "",
    "int global_counter = 0;",
    "pthread_mutex_t counter_mutex = PTHREAD_MUTEX_INITIALIZER;",
    "",
    "void *increment_counter(void *arg);",
    "",
    "int main() {",
    "  pthread_t threads[NUM_THREADS];",
    "",
    "  printf(\"Starting %d threads to increment a counter...\\n\", NUM_THREADS);",
    "",
    "  for (int i = 0; i < NUM_THREADS; i++) {",
    "    if (pthread_create(&threads[i], NULL, increment_counter, NULL) != 0) {",
    "      perror(\"Failed to create thread\");",
    "      exit(EXIT_FAILURE);",
    "    }",
    "  }",
    "",
    "  for (int i = 0; i < NUM_THREADS; i++) {",
    "    pthread_join(threads[i], NULL);",
    "  }",
    "",
    "  pthread_mutex_destroy(&counter_mutex);",
    "",
    "  printf(\"Final counter value: %d\\n\", global_counter);",
    "  printf(\"Expected value: %d\\n\", NUM_THREADS * INCREMENTS_PER_THREAD);",
    "",
    "  if (global_counter != NUM_THREADS * INCREMENTS_PER_THREAD) {",
    "    printf(\"ERROR: Race condition detected!\\n\");",
    "    exit(EXIT_FAILURE);",
    "  }",
    "",
    "  printf(\"Success! No race conditions detected.\\n\");",
    "  return 0;",
    "}",
    "",
    "void *increment_counter(void *arg) {",
    "  (void)arg;",
    "  for (int i = 0; i < INCREMENTS_PER_THREAD; i++) {",
    "    pthread_mutex_lock(&counter_mutex);",
    "    global_counter++;",
    "    pthread_mutex_unlock(&counter_mutex);",
    "  }",
    "  return NULL;",
    "}"
  ],
  "description": "Mutex-protected global counter increment using multithreading"
},

