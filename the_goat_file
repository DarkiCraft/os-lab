      "#include <stdio.h>",
      "#include <stdlib.h>",
      "#include <unistd.h>",
      "#include <sys/types.h>",
      "#include <sys/stat.h>",
      "#include <fcntl.h>",
      "#include <string.h>",
      "#include <errno.h>",
      "",
      "#define NODE_COUNT 5",
      "#define MAX_MSG_SIZE 32",
      "",
      "typedef struct {",
      "    int current_node;",
      "    int next_node;",
      "    int message;",
      "} node_connection;",
      "",
      "// Our linked list connections (simulating Node1->Node3->Node5->Node2->Node1)",
      "const int connections[NODE_COUNT] = {3, 5, 2, 1, -1};  // -1 marks end",
      "",
      "void create_fifo(int node) {",
      "    char fifo_name[20];",
      "    sprintf(fifo_name, \"/tmp/node%d_fifo\", node);",
      "    mkfifo(fifo_name, 0666);",
      "}",
      "",
      "void node_process(int node_id) {",
      "    char in_fifo[20], out_fifo[20];",
      "    int next_node = connections[node_id - 1];",
      "    ",
      "    sprintf(in_fifo, \"/tmp/node%d_fifo\", node_id);",
      "    ",
      "    if (next_node != -1) {",
      "        sprintf(out_fifo, \"/tmp/node%d_fifo\", next_node);",
      "    } else {",
      "        sprintf(out_fifo, \"/tmp/node%d_fifo\", 1);  // Loop back to first node",
      "    }",
      "    ",
      "    int in_fd = open(in_fifo, O_RDONLY);",
      "    int out_fd = open(out_fifo, O_WRONLY);",
      "    ",
      "    node_connection nc;",
      "    read(in_fd, &nc, sizeof(nc));",
      "    ",
      "    printf(\"Node %d received message: %d\\n\", node_id, nc.message);",
      "    ",
      "    // Process message (add node number)",
      "    nc.message += node_id;",
      "    nc.current_node = node_id;",
      "    nc.next_node = next_node == -1 ? 1 : next_node;  // Handle circular link",
      "    ",
      "    printf(\"Node %d sending message: %d to Node %d\\n\", ",
      "           node_id, nc.message, nc.next_node);",
      "    ",
      "    write(out_fd, &nc, sizeof(nc));",
      "    ",
      "    close(in_fd);",
      "    close(out_fd);",
      "}",
      "",
      "int main() {",
      "    // Create FIFOs for all nodes",
      "    for (int i = 1; i <= NODE_COUNT; i++) {",
      "        create_fifo(i);",
      "    }",
      "    ",
      "    pid_t pids[NODE_COUNT];",
      "    ",
      "    // Fork child processes for each node",
      "    for (int i = 0; i < NODE_COUNT; i++) {",
      "        pids[i] = fork();",
      "        if (pids[i] == 0) {",
      "            node_process(i + 1);  // Nodes are 1-based",
      "            exit(0);",
      "        }",
      "    }",
      "    ",
      "    // Parent initiates the message passing",
      "    sleep(1);  // Give children time to start",
      "    ",
      "    int out_fd = open(\"/tmp/node1_fifo\", O_WRONLY);",
      "    node_connection nc = {",
      "        .current_node = 0,  // Indicates origin",
      "        .next_node = 1,",
      "        .message = 0       // Initial message",
      "    };",
      "    ",
      "    printf(\"Parent sending initial message to Node 1\\n\");",
