  "dynamicShellScheduler pp": {
    "prefix": "dynamic Shell Scheduler shell runner by c",
    "body": [
      "#include <stdio.h>",
      "#include <stdlib.h>",
      "#include <unistd.h>",
      "#include <sys/wait.h>",
      "#include <string.h>",
      "",
      "#define NUM_TASKS 3",
      "",
      "int get_loops(char *script) {",
      "    FILE *fp = fopen(script, \"r\");",
      "    if (!fp) {",
      "        perror(\"File open failed\");",
      "        return 1;",
      "    }",
      "",
      "    char line[256];",
      "    int loop_count = 0;",
      "",
      "    while (fgets(line, sizeof(line), fp)) {",
      "        if (strstr(line, \"for ((\")) loop_count++;",
      "    }",
      "",
      "    fclose(fp);",
      "    return loop_count > 0 ? loop_count : 1;",
      "}",
      "",
      "void run_task(char *script, int duration) {",
      "    pid_t pid = fork();",
      "",
      "    if (pid == 0) {",
      "        printf(\"Running: %s for ~%d seconds...\\n\", script, duration);",
      "        execlp(\"bash\", \"bash\", script, NULL);",
      "        perror(\"Exec failed\");",
      "        exit(EXIT_FAILURE);",
      "    } else {",
      "        sleep(duration);",
      "        wait(NULL);",
      "    }",
      "}",
      "",
      "int main() {",
      "    char *scripts[NUM_TASKS] = {\"fact.sh\", \"prime.sh\", \"folder.sh\"};",
      "    int weights[NUM_TASKS];",
      "    int total_loops = 0;",
      "",
      "    for (int i = 0; i < NUM_TASKS; i++) {",
      "        weights[i] = get_loops(scripts[i]);",
      "        total_loops += weights[i];",
      "    }",
      "",
      "    printf(\"Total loops: %d\\n\", total_loops);",
      "",
      "    for (int i = 0; i < NUM_TASKS; i++) {",
      "        int time_slice = (weights[i] * 6) / total_loops + 1;",
      "        run_task(scripts[i], time_slice);",
      "    }",
      "",
      "    return 0;",
      "}"
    ],
    "description": "C program to schedule shell script execution based on loop count inside each script."
  },

