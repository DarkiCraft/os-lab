  "Readers-Writers (C - Pthreads & Semaphores)": {
    "prefix": "rwlock_c reader writer file share memory producer consumer ",
    "body": [
      "#include <stdio.h>",
      "#include <stdlib.h>",
      "#include <time.h>",
      "#include <semaphore.h>",
      "#include <pthread.h>",
      "",
      "#define NUM_READERS 5",
      "#define NUM_WRITERS 2",
      "#define STRING_LENGTH 60",
      "",
      "pthread_t readers[NUM_READERS], writers[NUM_WRITERS];",
      "sem_t mutex, rw_mutex;",
      "int readers_count = 0;",
      "FILE *file;",
      "",
      "char generateRandomChar() {",
      "\treturn (char)('a' + rand() % 26); // Generating a random lowercase character",
      "}",
      "",
      "void *reader(void *arg) {",
      "\twhile (1) {",
      "\t\tsem_wait(&mutex);",
      "\t\treaders_count++;",
      "\t\tif (readers_count == 1) {",
      "\t\t\tsem_wait(&rw_mutex);",
      "\t\t}",
      "\t\tsem_post(&mutex);",
      "",
      "\t\t// Reading from file",
      "\t\tfseek(file, 0, SEEK_SET);",
      "\t\tchar buffer[256];",
      "\t\twhile (fgets(buffer, sizeof(buffer), file) != NULL) {",
      "\t\t\tfprintf(stdout,\"Reader %ld: %s\", (long)arg, buffer);",
      "\t\t}",
      "",
      "\t\tsem_wait(&mutex);",
      "\t\treaders_count--;",
      "\t\tif (readers_count == 0) {",
      "\t\t\tsem_post(&rw_mutex);",
      "\t\t}",
      "\t\tsem_post(&mutex);",
      "",
      "\t\t// Perform other tasks",
      "\t\tusleep(1000);",
      "\t}",
      "}",
      "",
      "void *writer(void *arg) {",
      "\twhile (1) {",
      "\t\tsem_wait(&rw_mutex);",
      "",
      "\t\t// generate random string to be written to file",
      "\t\tsrand(time(NULL)); // Seed for random number generator",
      "\t\tchar randomString[STRING_LENGTH + 1]; // +1 for null terminator",
      "\t\tfor (int i = 0; i < STRING_LENGTH; i++) {",
      "\t\t\trandomString[i] = generateRandomChar();",
      "\t\t}",
      "\t\trandomString[STRING_LENGTH] = '\\0'; // Null terminate the string",
      "",
      "\t\t// Writing to file",
      "\t\tfseek(file, 0, SEEK_END);",
      "\t\tfprintf(file, \"%s\\n\",randomString); // writer to file on drive",
      "\t\tfprintf(stdout, \"Writer %ld: %s\\n\", (long)arg, randomString); // display",
      "\t\tfflush(file);",
      "",
      "\t\tsem_post(&rw_mutex);",
      "",
      "\t\t// Perform other tasks",
      "\t\tusleep(1000);",
      "\t}",
      "}",
      "",
      "int main() {",
      "\tfile = fopen(\"shared_file.txt\", \"a+\");",
      "\tif (file == NULL) {",
      "\t\tperror(\"Error opening file\");",
      "\t\texit(EXIT_FAILURE);",
      "\t}",
      "",
      "\tsem_init(&mutex, 0, 1); sem_init(&rw_mutex, 0, 1);",
      "",
      "\tint i;",
      "\tfor (i = 0; i < NUM_WRITERS; i++) pthread_create(&writers[i], NULL, writer, (void *)(long)i);",
      "\tfor (i = 0; i < NUM_READERS; i++) pthread_create(&readers[i], NULL, reader, (void *)(long)i);",
      "",
      "\tfor (i = 0; i < NUM_READERS; i++) pthread_join(readers[i], NULL);",
      "\tfor (i = 0; i < NUM_WRITERS; i++) pthread_join(writers[i], NULL);",
      "",
      "\tfprintf(stdout, \"reader pthread join completed\\n\");",
      "",
      "\tsem_destroy(&mutex); sem_destroy(&rw_mutex);",
      "\tfclose(file);",
      "\treturn 0;",
      "}"
    ],
    "description": "A complete Readers-Writers problem implementation in C using pthreads and semaphores"
  },

