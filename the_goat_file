      "#include <pthread.h>",
      "#include <semaphore.h>",
      "#include <unistd.h>",
      "#include <time.h>",
      "",
      "typedef struct {",
      "    int player_id;",
      "    int score;",
      "    int questions;",
      "    int time_limit;",
      "} player_data;",
      "",
      "sem_t semaphore;",
      "int current_question = 0;",
      "int num_players, num_questions, time_limit;",
      "int *answering_order;",
      "pthread_mutex_t lock;",
      "",
      "void* player_thread(void* arg) {",
      "    player_data* data = (player_data*)arg;",
      "    ",
      "    for (int q = 0; q < num_questions; q++) {",
      "        // Generate random response time (0 to time_limit*2)",
      "        int response_time = rand() % (data->time_limit * 2);",
      "        ",
      "        // Wait for question to start",
      "        while (current_question != q) { usleep(1000); }",
      "        ",
      "        // Try to acquire semaphore (answer question)",
      "        if (response_time <= data->time_limit) {",
      "            sem_wait(&semaphore);",
      "            ",
      "            // Record answering order",
      "            pthread_mutex_lock(&lock);",
      "            for (int i = 0; i < num_players; i++) {",
      "                if (answering_order[i] == -1) {",
      "                    answering_order[i] = data->player_id;",
      "                    break;",
      "                }",
      "            }",
      "            pthread_mutex_unlock(&lock);",
      "            ",
      "            // Simulate answering question",
      "            usleep(100000); // 100ms delay",
      "            ",
      "            sem_post(&semaphore);",
      "        }",
      "    }",
      "    return NULL;",
      "}",
      "",
      "void calculate_scores(int question) {",
      "    printf(\"\\nQuestion %d results:\\n\", question + 1);",
      "    printf(\"Answering order: \");",
      "    ",
      "    // Award points based on answering order",
      "    for (int i = 0; i < num_players; i++) {",
      "        int player_id = answering_order[i];",
      "        if (player_id == -1) continue;",
      "        ",
      "        printf(\"Player %d \", player_id);",
      "        if (i == 0) {",
      "            // First to answer gets 10 points",
      "            ((player_data*)thread_data[player_id-1])->score += 10;",
      "            printf(\"(10 pts) \");",
      "        } else if (i == 1) {",
      "            // Second gets 5 points",
      "            ((player_data*)thread_data[player_id-1])->score += 5;",
      "            printf(\"(5 pts) \");",
      "        } else {",
      "            // Others get 1 point",
      "            ((player_data*)thread_data[player_id-1])->score += 1;",
      "            printf(\"(1 pt) \");",
      "        }",
      "    }",
      "    printf(\"\\n\");",
      "}",
      "",
      "int main() {",
      "    srand(time(NULL));",
      "    ",
      "    // Get user input",
      "    printf(\"Enter number of players: \");",
      "    scanf(\"%d\", &num_players);",
      "    printf(\"Enter number of questions: \");",
      "    scanf(\"%d\", &num_questions);",
      "    printf(\"Enter time limit per question (in ms): \");",
      "    scanf(\"%d\", &time_limit);",
      "    ",
      "    // Initialize synchronization tools",
      "    sem_init(&semaphore, 0, 1);",
      "    pthread_mutex_init(&lock, NULL);",
      "    ",
      "    // Create thread data and answering order tracker",
      "    pthread_t threads[num_players];",
      "    player_data* thread_data[num_players];",
      "    answering_order = malloc(num_players * sizeof(int));",
      "    ",
      "    // Create player threads",
      "    for (int i = 0; i < num_players; i++) {",
      "        thread_data[i] = malloc(sizeof(player_data));",
      "        thread_data[i]->player_id = i + 1;",
      "        thread_data[i]->score = 0;",
      "        thread_data[i]->questions = num_questions;",
      "        thread_data[i]->time_limit = time_limit;",
      "        pthread_create(&threads[i], NULL, player_thread, thread_data[i]);",
      "    }",
      "    ",
      "    // Run quiz questions",
      "    for (int q = 0; q < num_questions; q++) {",
      "        // Reset answering order for new question",
      "        for (int i = 0; i < num_players; i++) answering_order[i] = -1;",
      "        ",
      "        printf(\"\\n--- Question %d ---\\n\", q + 1);",
      "        current_question = q;",
      "        ",
      "        // Wait for players to answer",
      "        sleep(1); // Simulate question time",
      "        ",
      "        // Calculate and display results",
      "        calculate_scores(q);",
      "    }",
      "    ",
      "    // Wait for threads to finish",
      "    for (int i = 0; i < num_players; i++) {",
      "        pthread_join(threads[i], NULL);",
      "    }",
      "    ",
      "    // Determine and display winner",
      "    int max_score = 0;",
      "    int winner = 0;",
      "    printf(\"\\nFinal Scores:\\n\");",
