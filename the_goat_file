  "sigaction_example": {
		"prefix": "sigaction example",
		"body": [
			"// int sigaction (int sig, const struct sigaction* new_act, struct sigaction* old_act);",
			"// Brief: Sets a callable function when a signal is detected by a thread (preferred over signal())",
			"//",
			"// Parameters: sig     - signal to \"assign\" (use defined macros i.e., SIGINT, SIGTERM, etc.)",
			"//             new_act - new action to assign to signal",
			"//                       -> Pass NULL to not assign anything, useful for querying current action via old_act",
			"//             old_act - old action, if needed",
			"//                       -> Pass NULL if old_act is not needed",
			"//",
			"// Returns:  0 on success; -1 on error, and errno is set",
			"//",
			"// Errors:",
			"// - EFAULT - passed new_act and old_act correspond to invalid memory",
			"// - EINVAL - invalid signal is passed | attempted to change action of SIGTERM and SIGSTOP",
			"//",
			"// Usage:",
			"void signal_handler(int sig) {",
			"    printf(\"Received signal: %d\\n\", sig);",
			"    // Cleanup and exit gracefully",
			"    exit(0);",
			"}",
			"",
			"int main() {",
			"    struct sigaction sa;",
			"    memset(&sa, 0, sizeof(sa));               // initialize to empty",
			"    sa.sa_handler = signal_handler;            // set signal handler",
			"    sigemptyset(&sa.sa_mask);                  // mask all signals during handler execution",
			"    sa.sa_flags = 0;                          // default flags",
			"    ",
			"    if (sigaction(SIGINT, &sa, NULL) == -1) { // set handler for SIGINT (Ctrl+C)",
			"        perror(\"sigaction\");",
			"        return EXIT_FAILURE;",
			"    }",
			"    ",
			"    printf(\"Press Ctrl+C to test signal handler...\\n\");",
			"    while (1) pause();  // wait for signal",
			"    ",
			"    return 0;",
			"}",
			"//",
			"// Flags: (not required in syllabus, only for extra info)",
			"//",
			"// Notes:",
			"// - actions for SIGKILL and SIGSTOP cannot be changed",
			"// - sa_handler and sa_sigaction (members of struct sigaction) might be a union",
			"//   -> DO NOT assign BOTH sa_handler and sa_sigaction. ONLY assign ONE",
			"// - A child created via fork() will inherit parent's signal dispositions",
			"//"
			// "// Search sigaction(2) for more information"
		],
		"description": "Example of using sigaction for signal handling (preferred over signal())"
	},
	"signal_example": {
		"prefix": "signal example",
		"body": [
			"//--------------------------------------------------------------------------------",
			"// Basics:",
			"// - When a signal is raised, it is sent to ALL threads",
			"// - A thread may block, ignore, or call a custom signal handler",
			"// - Signals may be sent via kill(), pthread_kill() in the program or via the terminal",
			"//--------------------------------------------------------------------------------",
			"// int signal(int sig, void (*sighandler)(int));",
			"// Brief: Sets a callable function when a signal is detected by a thread",
			"//",
			"// Parameters: sig        - signal to \"assign\" (use defined macros i.e., SIGINT, SIGTERM, etc.)",
			"//             sighandler - function to \"assign\" signal to",
			"//                          -> function must be of the form: void sighandler(int)",
			"//",
			"// Returns: previous value of the sighandler (SIG_DFL, SIG_IGN, etc.) on success, SIG_ERR on error, and errno is set",
			"//",
			"// Errors:",
			"// - EINVAL - sig is invalid",
			"//",
			"// Usage:",
			"void handle_signal(int sig) {",
			"    printf(\"Received signal: %d\\n\", sig);",
			"    // Cleanup and exit gracefully",
			"    exit(0);",
			"}",
			"",
			"int main() {",
			"    // Set custom handler for SIGINT (Ctrl+C)",
			"    if (signal(SIGINT, handle_signal) == SIG_ERR) {",
			"        perror(\"signal\");",
			"        return EXIT_FAILURE;",
			"    }",
			"",
			"    // Example of ignoring SIGTERM",
			"    if (signal(SIGTERM, SIG_IGN) == SIG_ERR) {",
			"        perror(\"signal\");",
			"        return EXIT_FAILURE;",
			"    }",
			"",
			"    printf(\"Press Ctrl+C to test signal handler...\\n\");",
			"    while (1) pause();  // wait for signal",
			"",
			"    return 0;",
			"}",
			"//",
			"// Notes:",
			"// - SIGTERM and SIGSTOP cannot be assigned new functions",
			"// - Implementation of signal() is extremely diverse on different systems",
			"// - Always prefer to use sigaction() (see b_sigaction.c)",
			"// - SIG_IGN may be specified in sighandler which will ignore the signal in that thread",
			"// - SIG_DFL may be specified in sighandler to restore default behavior (only portable part of signal())",
			"// - If some other sighandler is specified (some custom function), then it flows as follows:",
			"//   -> signal disposition is reset to SIG_DFL (or it might not be)",
			"//   -> signal is blocked temporarily",
			"//   -> signal is passed to specified custom sighandler",
			"//   -> signal is unblocked after sighandler has executed",
			"// - Please note that the above flow is highly variable between systems and might not be true for all",
			"// - Using signal() in multithreaded programs is undefined",
			"//",
			"// Search signal(2) for more information",
			"//--------------------------------------------------------------------------------"
		],
		"description": "Example of using signal() for signal handling (note: prefer sigaction() instead)"
	},
	"bounded_buffer": {
		"prefix": "bounded buffer example",
		"body": [
			"// Bounded Buffer (Producer-Consumer) Implementation using Semaphores",
			"//---------------------------------------------------------------",
			"#include <stdio.h>",
			"#include <stdlib.h>",
			"#include <pthread.h>",
			"#include <semaphore.h>",
			"#include <unistd.h>",
			"",
			"#define BUFFER_SIZE 5",
			"",
			"// Shared buffer and indexes",
			"int buffer[BUFFER_SIZE];",
			"int in = 0, out = 0;",
			"",
			"// Semaphores and mutex",
			"sem_t empty;   // Counts empty slots",
			"sem_t full;    // Counts full slots",
			"pthread_mutex_t mutex;  // Protects buffer access",
			"",
			"// Producer thread function",
			"void* producer(void* arg) {",
			"    int item;",
			"    for (int i = 0; i < 10; i++) {",
			"        item = rand() % 100;  // Produce random item",
			"        ",
			"        sem_wait(&empty);    // Wait for empty slot",
			"        pthread_mutex_lock(&mutex);",
			"        ",
			"        // Critical Section: Add item to buffer",
			"        buffer[in] = item;",
			"        printf(\"Producer %ld: Inserted %d at %d\\n\", (long)arg, item, in);",
			"        in = (in + 1) % BUFFER_SIZE;",
			"        ",
			"        pthread_mutex_unlock(&mutex);",
			"        sem_post(&full);     // Signal that a slot is full",
			"        ",
			"        sleep(rand() % 2);   // Simulate work",
			"    }",
			"    return NULL;",
			"}",
			"",
			"// Consumer thread function",
			"void* consumer(void* arg) {",
			"    int item;",
			"    for (int i = 0; i < 10; i++) {",
			"        sem_wait(&full);     // Wait for full slot",
			"        pthread_mutex_lock(&mutex);",
			"        ",
			"        // Critical Section: Remove item from buffer",
			"        item = buffer[out];",
			"        printf(\"Consumer %ld: Removed %d from %d\\n\", (long)arg, item, out);",
			"        out = (out + 1) % BUFFER_SIZE;",
			"        ",
			"        pthread_mutex_unlock(&mutex);",
			"        sem_post(&empty);    // Signal that a slot is empty",
			"        ",
			"        sleep(rand() % 3);   // Simulate work",
			"    }",
			"    return NULL;",
			"}",
			"",
			"int main() {",
			"    pthread_t prod[3], cons[3];",
			"    ",
			"    // Initialize semaphores and mutex",
			"    sem_init(&empty, 0, BUFFER_SIZE);  // Initially all slots empty",
			"    sem_init(&full, 0, 0);             // Initially no full slots",
			"    pthread_mutex_init(&mutex, NULL);",
			"    ",
			"    // Create producer and consumer threads",
			"    for (long i = 0; i < 3; i++) {",
			"        pthread_create(&prod[i], NULL, producer, (void*)i);",
			"        pthread_create(&cons[i], NULL, consumer, (void*)i);",
			"    }",
			"    ",
			"    // Wait for all threads to complete",
			"    for (int i = 0; i < 3; i++) {",
			"        pthread_join(prod[i], NULL);",
			"        pthread_join(cons[i], NULL);",
			"    }",
			"    ",
			"    // Clean up",
			"    sem_destroy(&empty);",
			"    sem_destroy(&full);",
			"    pthread_mutex_destroy(&mutex);",
			"    ",
			"    return 0;",
			"}",
			"",
			"/*",
			"Key Concepts:",
			"1. Bounded buffer acts as shared fixed-size queue",
			"2. Semaphores coordinate access:",
			"   - 'empty' counts available slots (initialized to buffer size)",
			"   - 'full' counts filled slots (initialized to 0)",
			"3. Mutex protects actual buffer operations",
			"4. Producer workflow:",
			"   - Wait for empty slot (sem_wait(&empty))",
			"   - Lock mutex",
			"   - Insert item",
			"   - Unlock mutex",
			"   - Signal new full slot (sem_post(&full))",
			"5. Consumer workflow:",
			"   - Wait for full slot (sem_wait(&full))",
			"   - Lock mutex",
			"   - Remove item",
			"   - Unlock mutex",
			"   - Signal new empty slot (sem_post(&empty))",
			"6. Circular buffer prevents overflow",
			"*/"
		],
		"description": "Complete bounded buffer implementation with multiple producers/consumers using pthreads and semaphores"
	},
	"named_pipes_example": {
		"prefix": "named pipes basic syntax",
		"body": [
			"/*",
			"Named Pipes (FIFOs) in C",
			"----------------------------------------",
			"Key Concepts:",
			"1. FIFOs are special files that allow IPC between unrelated processes",
			"2. Created with mkfifo() and accessed like regular files (open/read/write/close)",
			"3. Blocking by default - writers block until readers open, and vice versa",
			"4. Persistent in filesystem until explicitly unlinked",
			"5. Can have multiple readers/writers but data may interleave",
			"*/",
			"",
			"//----------------------------------------",
			"// WRITER PROCESS (sender.c)",
			"//----------------------------------------",
			"#include <stdio.h>",
			"#include <stdlib.h>",
			"#include <fcntl.h>",
			"#include <sys/stat.h>",
			"#include <unistd.h>",
			"",
			"#define FIFO_NAME \"/tmp/my_fifo\"",
			"",
			"int main() {",
			"    int fd;",
			"    char data[] = \"Hello from writer!\";",
			"",
			"    // Create FIFO (ignore error if already exists)",
			"    mkfifo(FIFO_NAME, 0666);",
			"",
			"    printf(\"Writer: Opening FIFO...\\n\");",
			"    fd = open(FIFO_NAME, O_WRONLY);  // Blocks until reader opens",
			"",
			"    printf(\"Writer: Sending data...\\n\");",
			"    write(fd, data, sizeof(data));",
			"",
			"    close(fd);",
			"    printf(\"Writer: Data sent. Exiting.\\n\");",
			"",
			"    // Optional: Remove FIFO when done",
			"    // unlink(FIFO_NAME);",
			"    return 0;",
			"}",
			"",
			"//----------------------------------------",
			"// READER PROCESS (receiver.c)",
			"//----------------------------------------",
			"#include <stdio.h>",
			"#include <stdlib.h>",
			"#include <fcntl.h>",
			"#include <unistd.h>",
			"",
			"#define FIFO_NAME \"/tmp/my_fifo\"",
			"#define BUFFER_SIZE 1024",
			"",
			"int main() {",
			"    int fd;",
			"    char buffer[BUFFER_SIZE];",
			"",
			"    printf(\"Reader: Waiting for data...\\n\");",
			"    fd = open(FIFO_NAME, O_RDONLY);  // Blocks until writer opens",
			"",
			"    int bytes_read = read(fd, buffer, BUFFER_SIZE);",
			"    printf(\"Reader: Received %d bytes: %s\\n\", bytes_read, buffer);",
			"",
			"    close(fd);",
			"    return 0;",
			"}",
			"",
			"/*",
			"Compilation and Execution:",
			"1. Compile both programs:",
			"   gcc sender.c -o sender",
			"   gcc receiver.c -o receiver",
			"",
			"2. Run in separate terminals:",
			"   ./receiver  # Will block waiting for sender",
			"   ./sender    # In another terminal",
			"",
			"Important Notes:",
			"1. FIFOs persist after program exit - manually remove with unlink() or 'rm /tmp/my_fifo'",
			"2. For non-blocking I/O: open() with O_NONBLOCK flag",
			"3. Always check return values of mkfifo(), open(), read(), write() in production code",
			"4. FIFOs have limited capacity (typically 4KB-64KB depending on system)",
			"5. Atomic writes guaranteed if < PIPE_BUF (defined in <limits.h>, typically 512B-4KB)",
			"*/"
		],
		"description": "Complete named pipes (FIFO) example with writer and reader processes"
	},
	"named_pipe_message_example": {
		"prefix": "named pipe messaging",
		"body": [
			"/*",
			"Interactive Message Passing with Named Pipes",
			"--------------------------------------------",
			"Features:",
			"1. Two-way communication using TWO FIFOs",
			"2. Process1 sends messages -> FIFO1 -> Process2 receives",
			"3. Process2 replies -> FIFO2 -> Process1 receives",
			"4. Clean exit on \"exit\" message",
			"*/",
			"",
			"//----------------------------------------",
			"// PROCESS 1 (sender_and_receiver.c)",
			"//----------------------------------------",
			"#include <stdio.h>",
			"#include <stdlib.h>",
			"#include <string.h>",
			"#include <fcntl.h>",
			"#include <unistd.h>",
			"#include <sys/stat.h>",
			"",
			"#define FIFO1 \"/tmp/fifo1\"",
			"#define FIFO2 \"/tmp/fifo2\"",
			"#define BUFFER_SIZE 1024",
			"",
			"int main() {",
			"    int fd1, fd2;",
			"    char buffer[BUFFER_SIZE];",
			"",
			"    // Create FIFOs (skip if already exists)",
			"    mkfifo(FIFO1, 0666);",
			"    mkfifo(FIFO2, 0666);",
			"",
			"    printf(\"Process1: Waiting for Process2...\\n\");",
			"    fd1 = open(FIFO1, O_WRONLY);  // Send pipe",
			"    fd2 = open(FIFO2, O_RDONLY);  // Receive pipe",
			"    printf(\"Process1: Connection established!\\n\");",
			"",
			"    while (1) {",
			"        // Get user input",
			"        printf(\"Process1: Enter message (type 'exit' to quit): \");",
			"        fgets(buffer, BUFFER_SIZE, stdin);",
			"        buffer[strcspn(buffer, \"\\n\")] = 0;  // Remove newline",
			"",
			"        // Send message",
			"        write(fd1, buffer, strlen(buffer)+1);",
			"        ",
			"        if (strcmp(buffer, \"exit\") == 0) break;",
			"",
			"        // Wait for reply",
			"        read(fd2, buffer, BUFFER_SIZE);",
			"        printf(\"Process1: Received reply -> %s\\n\", buffer);",
			"    }",
			"",
			"    close(fd1);",
			"    close(fd2);",
			"    unlink(FIFO1);",
			"    unlink(FIFO2);",
			"    return 0;",
			"}",
			"",
			"//----------------------------------------",
			"// PROCESS 2 (receiver_and_sender.c)",
			"//----------------------------------------",
			"#include <stdio.h>",
			"#include <stdlib.h>",
			"#include <string.h>",
			"#include <fcntl.h>",
			"#include <unistd.h>",
			"#include <sys/stat.h>",
			"",
			"#define FIFO1 \"/tmp/fifo1\"",
			"#define FIFO2 \"/tmp/fifo2\"",
			"#define BUFFER_SIZE 1024",
			"",
			"int main() {",
			"    int fd1, fd2;",
			"    char buffer[BUFFER_SIZE];",
			"",
			"    printf(\"Process2: Waiting for Process1...\\n\");",
			"    fd1 = open(FIFO1, O_RDONLY);  // Receive pipe",
			"    fd2 = open(FIFO2, O_WRONLY);  // Send pipe",
			"    printf(\"Process2: Connection established!\\n\");",
			"",
			"    while (1) {",
			"        // Wait for message",
			"        read(fd1, buffer, BUFFER_SIZE);",
			"        printf(\"Process2: Received message -> %s\\n\", buffer);",
			"",
			"        if (strcmp(buffer, \"exit\") == 0) break;",
			"",
			"        // Prepare reply",
			"        printf(\"Process2: Enter reply: \");",
			"        fgets(buffer, BUFFER_SIZE, stdin);",
			"        buffer[strcspn(buffer, \"\\n\")] = 0;",
			"",
			"        // Send reply",
			"        write(fd2, buffer, strlen(buffer)+1);",
			"    }",
			"",
			"    close(fd1);",
			"    close(fd2);",
			"    return 0;",
			"}",
			"",
			"/*",
			"How to Run:",
			"1. Terminal 1:",
			"   gcc sender_and_receiver.c -o process1",
			"   ./process1",
			"",
			"2. Terminal 2:",
			"   gcc receiver_and_sender.c -o process2",
			"   ./process2",
			"",
			"Message Flow Example:",
			"Terminal1 (Process1)           Terminal2 (Process2)",
			"Enter message: Hello           Received: Hello",
			"                               Enter reply: Hi there!",
			"Received reply: Hi there!",
			"Enter message: How are you?    Received: How are you?",
			"                               Enter reply: I'm good!",
			"...",
			"Enter message: exit            (Process2 exits)",
			"",
			"Key Points:",
			"1. Uses two FIFOs for bidirectional communication",
			"2. Properly null-terminates strings",
			"3. Removes newlines from fgets() input",
			"4. Cleanly exits on \"exit\" command",
			"5. Includes proper cleanup (unlink)",
			"*/"
		],
		"description": "Interactive two-way message passing using named pipes with clean exit handling"
	},
