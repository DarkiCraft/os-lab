  "Multithreaded Array Sort with Merge": {
    "prefix": "multisort array sort and merge using threads",
    "body": [
      "#include <pthread.h>",
      "#include <stdio.h>",
      "#include <stdlib.h>",
      "",
      "#define ARRAY_SIZE 10",
      "",
      "typedef struct {",
      "  int *array;",
      "  int start;",
      "  int end;",
      "} SortParams;",
      "",
      "int compare(const void *a, const void *b);",
      "void *sort_thread(void *arg);",
      "void merge(int *array, int size);",
      "",
      "int main() {",
      "  int array[ARRAY_SIZE] = {5, 2, 9, 1, 7, 4, 8, 3, 6, 0};",
      "  pthread_t threads[2];",
      "  SortParams *params = malloc(2 * sizeof(SortParams));",
      "  int mid = ARRAY_SIZE / 2;",
      "",
      "  printf(\"Unsorted array: \");",
      "  for (int i = 0; i < ARRAY_SIZE; i++) {",
      "    printf(\"%d \", array[i]);",
      "  }",
      "  putchar('\\n');",
      "",
      "  params[0] = (SortParams){array, 0, mid};",
      "  params[1] = (SortParams){array, mid, ARRAY_SIZE};",
      "",
      "  pthread_create(&threads[0], NULL, sort_thread, &params[0]);",
      "  pthread_create(&threads[1], NULL, sort_thread, &params[1]);",
      "",
      "  pthread_join(threads[0], NULL);",
      "  pthread_join(threads[1], NULL);",
      "",
      "  merge(array, ARRAY_SIZE);",
      "",
      "  printf(\"Sorted array: \");",
      "  for (int i = 0; i < ARRAY_SIZE; i++) {",
      "    printf(\"%d \", array[i]);",
      "  }",
      "  putchar('\\n');",
      "",
      "  free(params);",
      "  return 0;",
      "}",
      "",
      "int compare(const void *a, const void *b) {",
      "  return (*(int *)a - *(int *)b);",
      "}",
      "",
      "void *sort_thread(void *arg) {",
      "  SortParams *params = (SortParams *)arg;",
      "  qsort(params->array + params->start, params->end - params->start, sizeof(int), compare);",
      "  return NULL;",
      "}",
      "",
      "void merge(int *array, int size) {",
      "  int mid = size / 2;",
      "  int *temp = malloc(size * sizeof(int));",
      "  int i = 0, j = mid, k = 0;",
      "",
      "  while (i < mid && j < size) {",
      "    if (array[i] < array[j]) {",
      "      temp[k++] = array[i++];",
      "    } else {",
      "      temp[k++] = array[j++];",
      "    }",
      "  }",
      "",
      "  while (i < mid) {",
      "    temp[k++] = array[i++];",
      "  }",
      "",
      "  while (j < size) {",
      "    temp[k++] = array[j++];",
      "  }",
      "",
      "  for (i = 0; i < size; i++) {",
      "    array[i] = temp[i];",
      "  }",
      "",
      "  free(temp);",
      "}"
    ],
    "description": "Multithreaded array sort in C using pthreads, qsort, and custom merge."
  },
    "Multithreaded Matrix Multiplication": {
      "prefix": "matrix mul 3x3 multiply",
      "body": [
        "#include <pthread.h>",
        "#include <stdio.h>",
        "#include <stdlib.h>",
        "",
        "#define SIZE 3",
        "",
        "int mat1[SIZE][SIZE], mat2[SIZE][SIZE], result[SIZE][SIZE];",
        "",
        "typedef struct {",
        "  int row;",
        "} ThreadData;",
        "",
        "void *compute_row(void *arg);",
        "",
        "int main() {",
        "  pthread_t threads[SIZE];",
        "",
        "  printf(\"Enter Matrix 1 (3x3):\\n\");",
        "  for (int i = 0; i < SIZE; i++) {",
        "    for (int j = 0; j < SIZE; j++) {",
        "      scanf(\"%d\", &mat1[i][j]);",
        "    }",
        "  }",
        "",
        "  printf(\"Enter Matrix 2 (3x3):\\n\");",
        "  for (int i = 0; i < SIZE; i++) {",
        "    for (int j = 0; j < SIZE; j++) {",
        "      scanf(\"%d\", &mat2[i][j]);",
        "    }",
        "  }",
        "",
        "  for (int i = 0; i < SIZE; i++) {",
        "    ThreadData *data = malloc(sizeof(ThreadData));",
        "    data->row = i;",
        "    pthread_create(&threads[i], NULL, compute_row, data);",
        "  }",
        "",
        "  for (int i = 0; i < SIZE; i++) {",
        "    pthread_join(threads[i], NULL);",
        "  }",
        "",
        "  printf(\"\\nResult Matrix:\\n\");",
        "  for (int i = 0; i < SIZE; i++) {",
        "    for (int j = 0; j < SIZE; j++) {",
        "      printf(\"%d \", result[i][j]);",
        "    }",
        "    putchar('\\n');",
        "  }",
        "",
        "  return 0;",
        "}",
        "",
        "void *compute_row(void *arg) {",
        "  ThreadData *data = (ThreadData *)arg;",
        "  int row = data->row;",
        "",
        "  for (int col = 0; col < SIZE; col++) {",
        "    result[row][col] = 0;",
        "    for (int k = 0; k < SIZE; k++) {",
        "      result[row][col] += mat1[row][k] * mat2[k][col];",
        "    }",
