          "float track_length;",
          "sem_t sem;",
          "pthread_mutex_t race_mutex = PTHREAD_MUTEX_INITIALIZER;",
          "int runners_finished = 0;",
          "int finish_order[MAX_RUNNERS];",
          "float finish_times[MAX_RUNNERS];",
          "time_t start_time;",
          "",
