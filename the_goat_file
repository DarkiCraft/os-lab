	"producer_consumer_example 2": {
		"prefix": "producer consumer example 2",
		"body": [
			"#include <stdio.h>",
			"#include <stdlib.h>",
			"#include <pthread.h>",
			"#include <unistd.h>",
			"",
			"#define BUFFER_SIZE 5",
			"",
			"int buffer[BUFFER_SIZE];",
			"int count = 0; // Items in buffer",
			"int in = 0;    // Producer index",
			"int out = 0;   // Consumer index",
			"",
			"pthread_mutex_t mutex = PTHREAD_MUTEX_INITIALIZER;",
			"pthread_cond_t cond_producer = PTHREAD_COND_INITIALIZER;",
			"pthread_cond_t cond_consumer = PTHREAD_COND_INITIALIZER;",
			"",
			"void* producer(void* arg) {",
			"    int item;",
			"    for (int i = 0; i < 10; i++) {",
			"        item = rand() % 100; // Produce item",
			"",
			"        pthread_mutex_lock(&mutex);",
			"        while (count == BUFFER_SIZE) { // Buffer full",
			"            pthread_cond_wait(&cond_producer, &mutex);",
			"        }",
			"",
			"        buffer[in] = item;",
			"        printf(\"Producer %ld: Inserted %d at %d\\n\", (long)arg, item, in);",
			"        in = (in + 1) % BUFFER_SIZE;",
			"        count++;",
			"",
			"        pthread_cond_signal(&cond_consumer);",
			"        pthread_mutex_unlock(&mutex);",
			"",
			"        sleep(rand() % 2); // Simulate work",
			"    }",
			"    return NULL;",
			"}",
			"",
			"void* consumer(void* arg) {",
			"    int item;",
			"    for (int i = 0; i < 10; i++) {",
			"        pthread_mutex_lock(&mutex);",
			"        while (count == 0) { // Buffer empty",
			"            pthread_cond_wait(&cond_consumer, &mutex);",
			"        }",
			"",
			"        item = buffer[out];",
			"        printf(\"Consumer %ld: Removed %d from %d\\n\", (long)arg, item, out);",
			"        out = (out + 1) % BUFFER_SIZE;",
			"        count--;",
			"",
			"        pthread_cond_signal(&cond_producer);",
			"        pthread_mutex_unlock(&mutex);",
			"",
			"        sleep(rand() % 3); // Simulate work",
			"    }",
			"    return NULL;",
			"}",
			"",
			"int main() {",
			"    pthread_t producers[2], consumers[2];",
			"",
			"    // Create producer threads",
			"    for (long i = 0; i < 2; i++) {",
			"        pthread_create(&producers[i], NULL, producer, (void*)i);",
			"    }",
			"",
			"    // Create consumer threads",
			"    for (long i = 0; i < 2; i++) {",
			"        pthread_create(&consumers[i], NULL, consumer, (void*)i);",
			"    }",
			"",
			"    // Wait for threads to complete",
			"    for (int i = 0; i < 2; i++) {",
			"        pthread_join(producers[i], NULL);",
			"        pthread_join(consumers[i], NULL);",
			"    }",
			"",
			"    return 0;",
			"}",
			"",
			"/*",
			"Key Components:",
			"1. Shared Buffer: Circular array with fixed size",
			"2. Mutex: Protects access to shared variables (count, in, out)",
			"3. Condition Variables:",
			"   - cond_producer: Signaled when consumer removes item",
			"   - cond_consumer: Signaled when producer adds item",
			"4. Producer Logic:",
			"   - Waits when buffer is full",
			"   - Inserts item and signals consumer",
			"5. Consumer Logic:",
			"   - Waits when buffer is empty",
			"   - Removes item and signals producer",
			"",
			"Compile & Run:",
			"gcc -pthread prod_cons.c -o prod_cons",
			"./prod_cons",
			"",
			"Sample Output:",
			"Producer 0: Inserted 83 at 0",
			"Consumer 0: Removed 83 from 0",
			"Producer 1: Inserted 86 at 1",
			"Producer 0: Inserted 77 at 2",
			"Consumer 1: Removed 86 from 1",
			"...",
			"*/"
		],
		"description": "Complete producer-consumer solution using pthreads with mutex and condition variables"
	},
  
