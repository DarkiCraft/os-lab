            "",
            "typedef struct {",
            "  char script[30];",
            "  int at, bt, rt, finished, tat;",
            "} Process;",
            "",
            "int main() {",
            "  Process p[N] = {",
            "    {\"./find_special.sh\", 0, 2, 2, 0, 0},",
